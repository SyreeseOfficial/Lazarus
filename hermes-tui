#!/usr/bin/env python3
"""hermes-tui — text-based TUI for Hermes Agent"""

import collections, curses, os, re, shutil, subprocess, threading, time
from datetime import datetime
from pathlib import Path

# ─── Config ───────────────────────────────────────────────────────────────────

_CONFIG = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "hermes-ctl/config"

SERVICE_NAME    = "hermes-gateway"
HERMES_DIR      = Path.home() / ".hermes/hermes-agent"
LOG_LINES       = 100
NOTIFY          = True
RESTORE_PROFILE = ""

if _CONFIG.exists():
    for _l in _CONFIG.read_text().splitlines():
        if "=" in _l and not _l.startswith("#"):
            _k, _, _v = _l.partition("=")
            match _k.strip():
                case "SERVICE_NAME":    SERVICE_NAME    = _v.strip()
                case "HERMES_DIR":      HERMES_DIR      = Path(_v.strip())
                case "LOG_LINES":       LOG_LINES       = int(_v.strip())
                case "NOTIFY_ON_TIMER": NOTIFY          = _v.strip().lower() == "true"
                case "RESTORE_PROFILE": RESTORE_PROFILE = _v.strip()

# ─── Helpers ──────────────────────────────────────────────────────────────────

def _sh(*cmd):
    return subprocess.run(cmd, capture_output=True, text=True)

def _active():
    return _sh("systemctl", "--user", "is-active", SERVICE_NAME).returncode == 0

def _ppd():
    return bool(shutil.which("powerprofilesctl"))

def _fmt(s):
    s = max(s, 0)
    d, s = divmod(s, 86400)
    h, s = divmod(s, 3600)
    m = s // 60
    if d: return f"{d}d {h}h"
    if h: return f"{h}h {m}m"
    return f"{m}m"

def _get_status():
    active = _active()
    info = {"active": active}
    if active:
        r = _sh("systemctl", "--user", "show", SERVICE_NAME,
                "--property=MainPID,ActiveEnterTimestamp")
        for line in r.stdout.splitlines():
            k, _, v = line.partition("=")
            info[k] = v
        ts = info.get("ActiveEnterTimestamp", "")
        r2 = _sh("date", "-d", ts, "+%s")
        if r2.returncode == 0 and r2.stdout.strip().isdigit():
            info["uptime"] = _fmt(int(datetime.now().timestamp()) - int(r2.stdout.strip()))
    if _ppd():
        info["power"] = _sh("powerprofilesctl", "get").stdout.strip()
    if _sh("systemctl", "--user", "is-active", "hermes-ctl-autostop.timer").returncode == 0:
        r = _sh("systemctl", "--user", "show", "hermes-ctl-autostop.timer",
                "--property=NextElapseUSecRealtime")
        v = r.stdout.strip().split("=")[-1]
        if v.isdigit() and int(v) > 0:
            ns = int(v) // 1_000_000
            rem = ns - int(datetime.now().timestamp())
            info["timer"] = f"{_fmt(rem)} (at {datetime.fromtimestamp(ns):%H:%M})"
    info["boot"]    = _sh("systemctl", "--user", "is-enabled", SERVICE_NAME).stdout.strip()
    r = _sh("git", "-C", str(HERMES_DIR), "log", "-1", "--format=%h")
    info["version"] = r.stdout.strip() if r.returncode == 0 else "?"
    return info

