# ─── App ─────────────────────────────────────────────────────────────────────

class App:
    def __init__(self, scr):
        self.scr          = scr
        self._lock        = threading.Lock()
        self.logs         = collections.deque(maxlen=500)
        self.status       = {}
        self.mode         = "normal"
        self._cfn         = None
        self._cmsg        = ""
        self._ifn         = None
        self._iprompt     = ""
        self._ibuf        = ""
        self._log_off     = 0
        self._help_off    = 0
        self._wake        = threading.Event()

    def run(self):
        curses.curs_set(0)
        curses.use_default_colors()
        if curses.has_colors():
            curses.init_pair(1, curses.COLOR_GREEN,  -1)  # running
            curses.init_pair(2, curses.COLOR_RED,    -1)  # stopped
            curses.init_pair(3, curses.COLOR_YELLOW, -1)  # keys / prompts
            curses.init_pair(4, curses.COLOR_CYAN,   -1)  # borders

        self.scr.keypad(True)
        self.scr.nodelay(True)

        threading.Thread(target=self._tail_logs,   daemon=True).start()
        threading.Thread(target=self._status_loop, daemon=True).start()

        while True:
            self._draw()
            ch = self.scr.getch()
            if ch != -1:
                self._handle(ch)
            time.sleep(0.05)

    # ── Draw ──────────────────────────────────────────────────────────────────

    def _draw(self):
        try:
            self._draw_inner()
        except curses.error:
            pass

    def _draw_inner(self):
        scr = self.scr
        H, W = scr.getmaxyx()
        scr.erase()

        G = curses.color_pair(1) | curses.A_BOLD  # green bold  (running)
        R = curses.color_pair(2) | curses.A_BOLD  # red bold    (stopped)
        Y = curses.color_pair(3) | curses.A_BOLD  # yellow bold (keys / prompts)
        C = curses.color_pair(4)                   # cyan        (borders)
        D = curses.A_DIM

        # row 0 — top border + title
        title = f" Hermes  {SERVICE_NAME} "
        self._p(0, 0, "┌─" + title + "─" * (W - len(title) - 3) + "┐", C)

        # row 1 — status
        self._p(1, 0, "│", C)
        self._p(1, W - 1, "│", C)
        s = self.status
        col = 2
        if s:
            if s.get("active"):
                col = self._p(1, col, "●", G) + 1
                col = self._p(1, col, "RUNNING", G) + 2
                if pid := s.get("MainPID"): col = self._p(1, col, f"PID {pid}", 0) + 2
                if up  := s.get("uptime"):  col = self._p(1, col, f"Up {up}",   0) + 2
            else:
                col = self._p(1, col, "○", R) + 1
                col = self._p(1, col, "STOPPED", R) + 2
            if pw  := s.get("power"):   col = self._p(1, col, f"pwr:{pw}",    D) + 2
            if bt  := s.get("boot"):    col = self._p(1, col, f"boot:{bt}",   D) + 2
            if tm  := s.get("timer"):   col = self._p(1, col, f"timer:{tm}",  Y) + 2
            if ver := s.get("version"):      self._p(1, col, f"git:{ver}",    D)
        else:
            self._p(1, col, "loading...", D)

        ctop = 3
        cbot = H - 2

        if self.mode == "help":
            # full-width help screen
            self._p(2, 0, "├" + "─" * (W - 2) + "┤", C)
            content_h = cbot - ctop
            visible_h = _HELP[self._help_off : self._help_off + content_h]
            for i, line in enumerate(visible_h):
                self._p(ctop + i, 0,     "│", C)
                self._p(ctop + i, W - 1, "│", C)
                self._p(ctop + i, 2, line[:W - 4], 0)
            for row in range(ctop + len(visible_h), cbot):
                self._p(row, 0,     "│", C)
                self._p(row, W - 1, "│", C)
            self._p(H - 2, 0, "├" + "─" * (W - 2) + "┤", C)
            self._p(H - 1, 0,     "│", C)
            self._p(H - 1, W - 1, "│", C)
            curses.curs_set(0)
            self._p(H - 1, 2, "PgUp/Dn:scroll  any key:close", D)
        else:
            # split: menu left, logs right
            self._p(2, 0, "├" + "─" * MENU_W + "┬" + "─" * (W - MENU_W - 3) + "┤", C)

            log_h = cbot - ctop
            log_w = W - MENU_W - 4

            row = ctop
            for item in _MENU:
                if row >= cbot:
                    break
                self._p(row, 0,        "│", C)
                self._p(row, MENU_W+1, "│", C)
                self._p(row, W-1,      "│", C)
                if item is None:
                    self._p(row, 1, "─" * MENU_W, D)
                else:
                    key, label = item
                    self._p(row, 2, f"[{key}]", Y)
                    self._p(row, 6, label, 0)
                row += 1

            while row < cbot:
                self._p(row, 0,        "│", C)
                self._p(row, MENU_W+1, "│", C)
                self._p(row, W-1,      "│", C)
                row += 1

            with self._lock:
                logs = list(self.logs)
            n = len(logs)
            if self._log_off == 0:
                visible = logs[-log_h:]
            else:
                end = n - self._log_off
                visible = logs[max(0, end - log_h):end]
            for i, line in enumerate(visible):
                self._p(ctop + i, MENU_W + 3, line[:log_w], D)

            self._p(H - 2, 0, "├" + "─" * MENU_W + "┴" + "─" * (W - MENU_W - 3) + "┤", C)

            self._p(H - 1, 0,     "│", C)
            self._p(H - 1, W - 1, "│", C)
            if self.mode == "confirm":
                self._p(H - 1, 2, f"{self._cmsg}  [y/N]", Y)
            elif self.mode == "input":
                self._p(H - 1, 2, f"{self._iprompt}{self._ibuf}_", Y)
                curses.curs_set(1)
            else:
                curses.curs_set(0)
                self._p(H - 1, 2, "h:help  R:refresh  PgUp/Dn:scroll  q:quit", D)

        scr.refresh()

    def _p(self, row, col, text, attr=0):
        """Write text at (row, col); return end column. Silently clips and ignores errors."""
        H, W = self.scr.getmaxyx()
        if row >= H or col >= W:
            return col + len(text)
        text = text[:W - col]
        try:
            self.scr.addstr(row, col, text, attr)
        except curses.error:
            pass
        return col + len(text)

    # ── Background threads ────────────────────────────────────────────────────

    def _status_loop(self):
        while True:
            s = _get_status()
            with self._lock:
                self.status = s
            self._wake.wait(timeout=2)
            self._wake.clear()

    def _tail_logs(self):
        proc = subprocess.Popen(
            ["journalctl", "--user", "-u", SERVICE_NAME,
             f"-n{LOG_LINES}", "-f", "--no-pager", "--output=short"],
            stdout=subprocess.PIPE, stderr=subprocess.DEVNULL,
        )
        for raw in proc.stdout:
            with self._lock:
                self.logs.append(raw.decode().rstrip())

    # ── Key dispatch ──────────────────────────────────────────────────────────

    def _handle(self, ch):
        if self.mode == "help":
            H, _ = self.scr.getmaxyx()
            content_h = H - 5
            max_off = max(0, len(_HELP) - content_h)
            if ch == curses.KEY_PPAGE:
                self._help_off = max(0, self._help_off - content_h // 2)
            elif ch == curses.KEY_NPAGE:
                self._help_off = min(max_off, self._help_off + content_h // 2)
            else:
                self.mode = "normal"
            return

        if self.mode == "confirm":
            if ch in (ord("y"), ord("Y")):
                fn, args = self._cfn
                self.mode = "normal"
                threading.Thread(target=fn, args=args, daemon=True).start()
            else:
                self.mode = "normal"
            return

        if self.mode == "input":
            if ch in (curses.KEY_ENTER, 10, 13):
                val = self._ibuf.strip()
                fn  = self._ifn
                self.mode  = "normal"
                self._ibuf = ""
                if val and fn:
                    threading.Thread(target=fn, args=(val,), daemon=True).start()
            elif ch in (curses.KEY_BACKSPACE, 127, 8):
                self._ibuf = self._ibuf[:-1]
            elif ch == 27:
                self.mode  = "normal"
                self._ibuf = ""
            elif 32 <= ch < 127:
                self._ibuf += chr(ch)
            return

        if ch == curses.KEY_PPAGE:
            H, _ = self.scr.getmaxyx()
            with self._lock:
                n = len(self.logs)
            self._log_off = min(self._log_off + (H - 5) // 2, max(0, n - (H - 5)))
            return
        if ch == curses.KEY_NPAGE:
            H, _ = self.scr.getmaxyx()
            self._log_off = max(0, self._log_off - (H - 5) // 2)
            return

        key = chr(ch) if 32 <= ch < 127 else None
        match key:
            case "q": raise SystemExit
            case "R": self._wake.set()
            case "s": self._confirm("Start the agent?",             self._do_start)
            case "S": self._confirm("Stop the agent?",              self._do_stop)
            case "r": self._confirm("Restart the agent?",           self._do_restart)
            case "e": self._confirm("Enable autostart on login?",   self._do_boot,  "enable")
            case "d": self._confirm("Disable autostart on login?",  self._do_boot,  "disable")
            case "t": self._ask("Timer (30m · 2h · 1h30m · HH:MM): ", self._do_timer_set)
            case "x": self._confirm("Cancel the auto-stop timer?",  self._do_timer_cancel)
            case "u": self._confirm("Pull latest Hermes code?",     self._do_update)
            case "c": self._show_config()
            case "h": self.mode = "help"; self._help_off = 0

    def _confirm(self, msg, fn, *args):
        self._cmsg = msg
        self._cfn  = (fn, args)
        self.mode  = "confirm"

    def _ask(self, prompt, fn):
        self._iprompt = prompt
        self._ifn     = fn
        self._ibuf    = ""
        self.mode     = "input"

    def _log(self, msg):
        with self._lock:
            self.logs.append(f"[tui] {msg}")

    # ── Service actions ───────────────────────────────────────────────────────

    def _do_start(self):
        _sh("systemctl", "--user", "start", SERVICE_NAME)
        if _ppd(): _sh("powerprofilesctl", "set", "power-saver")
        self._wake.set()

    def _do_stop(self):
        _sh("systemctl", "--user", "stop", SERVICE_NAME)
        if _ppd() and RESTORE_PROFILE: _sh("powerprofilesctl", "set", RESTORE_PROFILE)
        self._wake.set()

    def _do_restart(self):
        _sh("systemctl", "--user", "restart", SERVICE_NAME)
        if _ppd(): _sh("powerprofilesctl", "set", "power-saver")
        self._wake.set()

    def _do_boot(self, sub):
        _sh("systemctl", "--user", sub, SERVICE_NAME)
        self._wake.set()

    # ── Timer actions ─────────────────────────────────────────────────────────

    def _do_timer_set(self, spec):
        _sh("systemctl", "--user", "stop", "hermes-ctl-autostop.timer")
        _sh("systemctl", "--user", "stop", "hermes-ctl-autostop.service")
        if re.match(r"^\d{1,2}:\d{2}$", spec):
            flag = f"--on-calendar={spec}"
        elif re.match(r"^\d+[hm](\d+m)?$", spec):
            flag = f"--on-active={spec}"
        else:
            self._log(f"Invalid spec: {spec!r}  (use 30m, 2h, 1h30m, or HH:MM)")
            return
        cmd = f"systemctl --user stop {SERVICE_NAME}"
        if NOTIFY and shutil.which("notify-send"):
            cmd = f"notify-send 'Hermes Agent' 'Timer expired'; {cmd}"
        _sh("systemd-run", "--user", flag, "--unit=hermes-ctl-autostop",
            "/bin/bash", "-c", cmd)
        self._wake.set()

    def _do_timer_cancel(self):
        _sh("systemctl", "--user", "stop", "hermes-ctl-autostop.timer")
        _sh("systemctl", "--user", "stop", "hermes-ctl-autostop.service")
        self._wake.set()

    # ── Update ────────────────────────────────────────────────────────────────

    def _do_update(self):
        if not HERMES_DIR.is_dir():
            self._log(f"Not found: {HERMES_DIR}")
            return
        _sh("git", "-C", str(HERMES_DIR), "fetch", "-q")
        r = _sh("git", "-C", str(HERMES_DIR), "log", "HEAD..@{u}", "--oneline")
        if not r.stdout.strip():
            self._log("Already up to date.")
            return
        was_running = _active()
        res = _sh("git", "-C", str(HERMES_DIR), "pull")
        for line in r.stdout.splitlines():
            self._log(line)
        self._log(res.stdout.strip() or "Updated.")
        self._wake.set()
        if was_running:
            self._confirm("Restart Hermes now?", self._do_restart)

    # ── Config ────────────────────────────────────────────────────────────────

    def _show_config(self):
        self._log(f"config file: {_CONFIG}")
        self._log(f"  SERVICE_NAME    = {SERVICE_NAME}")
        self._log(f"  HERMES_DIR      = {HERMES_DIR}")
        self._log(f"  LOG_LINES       = {LOG_LINES}")
        self._log(f"  NOTIFY_ON_TIMER = {NOTIFY}")
        self._log(f"  RESTORE_PROFILE = {RESTORE_PROFILE or '<none>'}")


def _main(scr):
    App(scr).run()


if __name__ == "__main__":
    try:
        curses.wrapper(_main)
    except SystemExit:
        pass
